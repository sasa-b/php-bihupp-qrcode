{
    "name": "sasa-b/php-bihupp-qrcode",
    "description": "Library implementing the BIHUPP QR Code standard for representing bank payment instructions as QR Codes",
    "type": "library",
    "keywords": ["bihupp", "bihupp10", "qr code", "qrcode", "payment instruction", "bank transfer", "bosnia", "hercegovina", "platni promet"],
    "version": "0.2.3",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "chillerlan/php-qrcode": "^6.0.0",
        "khanamiryan/qrcode-detector-decoder": "^2.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Sco\\BihuppQRCode\\": "src/"

        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sco\\BihuppQRCode\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "authors": [
        {
            "name": "Sasa Blagojevic",
            "email": "sasa.blagojevic@mail.com"
        }
    ],
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "kubawerlos/php-cs-fixer-custom-fixers": "^3.36",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.5"
    },
    "scripts": {
        "php-cs-fixer": [
            "vendor/bin/php-cs-fixer fix --allow-risky=yes --config=.php-cs-fixer.dist.php"
        ],
        "phpstan": [
            "php -d memory_limit=2G vendor/bin/phpstan analyse --configuration=phpstan.neon.dist"
        ],
        "code:quality": [
            "@php-cs-fixer",
            "@phpstan"
        ]
    }
}
